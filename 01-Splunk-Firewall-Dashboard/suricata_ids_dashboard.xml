      <chart>
        <search>
          <query>index=botsv1 sourcetype="fortigate_traffic" action=blocked |stats count by src_ip 
| iplocation src_ip | stats sum(count) as count by Country | sort - count 
| head 10</query>
          <earliest>0</earliest>
          <sampleRatio>1</sampleRatio>
        </search>
